#!/usr/bin/env bash
# deep-research — OpenAI Deep Research API wrapper
# Usage: deep-research <model> <query> [--max-tool-calls N] [--poll-interval S]
#        deep-research <model> -- <query that may start with dashes>
#
# Models: o3-deep-research-2025-06-26 | o4-mini-deep-research-2025-06-26
# Requires: OPENAI_API_KEY (via secrets4claude)

set -euo pipefail

# --- Dependency check ---
for cmd in curl jq; do
  command -v "$cmd" >/dev/null 2>&1 || { echo "ERROR: '$cmd' is required but not found." >&2; exit 1; }
done

# --- Defaults ---
MAX_TOOL_CALLS="${MAX_TOOL_CALLS:-}"
POLL_INTERVAL="${POLL_INTERVAL:-15}"
TIMEOUT="${TIMEOUT:-1800}"  # 30 min max
CURL_MAX_TIME=60
CURL_CONNECT_TIMEOUT=15
MAX_CONSECUTIVE_ERRORS=3

# --- Parse args ---
MODEL=""
QUERY=""
QUERY_MODE=false
while [[ $# -gt 0 ]]; do
  if [[ "$QUERY_MODE" == "true" ]]; then
    # After --, everything is query
    if [[ -z "$QUERY" ]]; then QUERY="$1"; else QUERY="$QUERY $1"; fi
    shift; continue
  fi
  case "$1" in
    --max-tool-calls) MAX_TOOL_CALLS="$2"; shift 2 ;;
    --poll-interval)  POLL_INTERVAL="$2"; shift 2 ;;
    --timeout)        TIMEOUT="$2"; shift 2 ;;
    --)               QUERY_MODE=true; shift ;;
    *)
      if [[ -z "$MODEL" ]]; then
        MODEL="$1"
      elif [[ -z "$QUERY" ]]; then
        QUERY="$1"
      else
        QUERY="$QUERY $1"
      fi
      shift
      ;;
  esac
done

if [[ -z "$MODEL" || -z "$QUERY" ]]; then
  echo "Usage: deep-research <model-id> <query> [--max-tool-calls N] [--poll-interval S] [--timeout S]" >&2
  echo "       deep-research <model-id> -- <query that starts with dashes>" >&2
  echo "Models: o3-deep-research-2025-06-26 | o4-mini-deep-research-2025-06-26" >&2
  exit 1
fi

if [[ -z "${OPENAI_API_KEY:-}" ]]; then
  echo "ERROR: OPENAI_API_KEY is not set. Run secrets4claude first." >&2
  exit 1
fi

# Validate MAX_TOOL_CALLS is numeric
if [[ -n "$MAX_TOOL_CALLS" ]] && ! [[ "$MAX_TOOL_CALLS" =~ ^[0-9]+$ ]]; then
  echo "ERROR: --max-tool-calls must be a positive integer, got: $MAX_TOOL_CALLS" >&2
  exit 1
fi

# --- Build request body ---
TOOLS='[{"type":"web_search_preview"},{"type":"code_interpreter","container":{"type":"auto"}}]'

# Build JSON payload safely with jq
BODY=$(jq -n \
  --arg model "$MODEL" \
  --arg query "$QUERY" \
  --argjson tools "$TOOLS" \
  '{
    model: $model,
    input: [
      {
        role: "developer",
        content: [{type: "input_text", text: "You are a professional researcher. Produce a structured, data-driven report with inline citations. Write in the same language as the user query."}]
      },
      {
        role: "user",
        content: [{type: "input_text", text: $query}]
      }
    ],
    tools: $tools,
    reasoning: {summary: "auto"},
    background: true
  }')

# Add max_tool_calls if specified
if [[ -n "$MAX_TOOL_CALLS" ]]; then
  BODY=$(echo "$BODY" | jq --argjson mtc "$MAX_TOOL_CALLS" '. + {max_tool_calls: $mtc}')
fi

# --- Helper: robust curl wrapper ---
_curl_api() {
  local url="$1"; shift
  curl -fSs \
    --max-time "$CURL_MAX_TIME" \
    --connect-timeout "$CURL_CONNECT_TIMEOUT" \
    --retry 2 --retry-delay 3 --retry-all-errors \
    -H "Authorization: Bearer $OPENAI_API_KEY" \
    ${OPENAI_ORGANIZATION_ID:+-H "OpenAI-Organization: $OPENAI_ORGANIZATION_ID"} \
    ${OPENAI_PROJECT_ID:+-H "OpenAI-Project: $OPENAI_PROJECT_ID"} \
    "$@" "$url"
}

# --- Submit request ---
echo ">>> Submitting deep research request..." >&2
echo ">>> Model: $MODEL" >&2
echo ">>> Query length: ${#QUERY} chars" >&2

SUBMIT_RESPONSE=$(_curl_api "https://api.openai.com/v1/responses" \
  -H "Content-Type: application/json" \
  -d "$BODY") || {
  echo "ERROR: HTTP request to submit deep research failed." >&2
  echo "$SUBMIT_RESPONSE" >&2
  exit 1
}

# Validate JSON response
if ! echo "$SUBMIT_RESPONSE" | jq empty 2>/dev/null; then
  echo "ERROR: Non-JSON response from API:" >&2
  echo "$SUBMIT_RESPONSE" | head -20 >&2
  exit 1
fi

# Extract response ID and status
RESPONSE_ID=$(echo "$SUBMIT_RESPONSE" | jq -r '.id // empty')
STATUS=$(echo "$SUBMIT_RESPONSE" | jq -r '.status // empty')

if [[ -z "$RESPONSE_ID" ]]; then
  echo "ERROR: Failed to submit request. API response:" >&2
  echo "$SUBMIT_RESPONSE" | jq '.error // .' 2>/dev/null || echo "$SUBMIT_RESPONSE" >&2
  exit 1
fi

echo ">>> Response ID: $RESPONSE_ID" >&2
echo ">>> Initial status: $STATUS" >&2

# --- Poll for completion ---
# Initialize POLL_RESPONSE for cases where status is already terminal (HIGH #1 fix)
POLL_RESPONSE="$SUBMIT_RESPONSE"
ELAPSED=0
CONSECUTIVE_ERRORS=0

while [[ "$STATUS" != "completed" && "$STATUS" != "failed" && "$STATUS" != "cancelled" ]]; do
  if [[ $ELAPSED -ge $TIMEOUT ]]; then
    echo "ERROR: Timeout after ${TIMEOUT}s. Response ID: $RESPONSE_ID (you can resume polling manually)" >&2
    exit 1
  fi

  echo ">>> Status: $STATUS — waiting ${POLL_INTERVAL}s (elapsed: ${ELAPSED}s)..." >&2
  sleep "$POLL_INTERVAL"
  ELAPSED=$((ELAPSED + POLL_INTERVAL))

  # Poll with error handling
  POLL_RAW=$(_curl_api "https://api.openai.com/v1/responses/$RESPONSE_ID") || {
    CONSECUTIVE_ERRORS=$((CONSECUTIVE_ERRORS + 1))
    echo ">>> WARN: Poll request failed (attempt $CONSECUTIVE_ERRORS/$MAX_CONSECUTIVE_ERRORS)" >&2
    if [[ $CONSECUTIVE_ERRORS -ge $MAX_CONSECUTIVE_ERRORS ]]; then
      echo "ERROR: $MAX_CONSECUTIVE_ERRORS consecutive poll failures. Response ID: $RESPONSE_ID" >&2
      exit 1
    fi
    continue
  }

  # Validate JSON
  if ! echo "$POLL_RAW" | jq empty 2>/dev/null; then
    CONSECUTIVE_ERRORS=$((CONSECUTIVE_ERRORS + 1))
    echo ">>> WARN: Non-JSON poll response (attempt $CONSECUTIVE_ERRORS/$MAX_CONSECUTIVE_ERRORS)" >&2
    if [[ $CONSECUTIVE_ERRORS -ge $MAX_CONSECUTIVE_ERRORS ]]; then
      echo "ERROR: $MAX_CONSECUTIVE_ERRORS consecutive invalid responses. Last response:" >&2
      echo "$POLL_RAW" | head -10 >&2
      exit 1
    fi
    continue
  fi

  # Success — reset error counter and update state
  CONSECUTIVE_ERRORS=0
  POLL_RESPONSE="$POLL_RAW"
  STATUS=$(echo "$POLL_RESPONSE" | jq -r '.status // "unknown"')
done

# --- Handle final status ---
if [[ "$STATUS" != "completed" ]]; then
  echo "ERROR: Research ended with status: $STATUS" >&2
  echo "$POLL_RESPONSE" | jq '.error // .incomplete_details // .' >&2
  exit 1
fi

echo ">>> Research completed! (${ELAPSED}s)" >&2

# --- Extract results ---
# Final report is typically the last message in output
REPORT=$(echo "$POLL_RESPONSE" | jq -r '
  [.output[] | select(.type == "message") | .content[]? | select(.type == "output_text") | .text] | last // "No report text found"
')

# Extract citations
CITATIONS=$(echo "$POLL_RESPONSE" | jq '[
  .output[] | select(.type == "message") | .content[]? | select(.type == "output_text") | .annotations[]? |
  {title: .title, url: .url}
] | unique_by(.url)')

# Count web searches for cost tracking
WEB_SEARCH_COUNT=$(echo "$POLL_RESPONSE" | jq '[.output[] | select(.type == "web_search_call")] | length')

# Token usage
USAGE=$(echo "$POLL_RESPONSE" | jq '.usage // {}')
INPUT_TOKENS=$(echo "$USAGE" | jq '.input_tokens // 0')
OUTPUT_TOKENS=$(echo "$USAGE" | jq '.output_tokens // 0')

# --- Output results as JSON ---
jq -n \
  --arg report "$REPORT" \
  --argjson citations "$CITATIONS" \
  --argjson web_searches "$WEB_SEARCH_COUNT" \
  --argjson input_tokens "$INPUT_TOKENS" \
  --argjson output_tokens "$OUTPUT_TOKENS" \
  --arg model "$MODEL" \
  --argjson elapsed "$ELAPSED" \
  --arg response_id "$RESPONSE_ID" \
  '{
    report: $report,
    citations: $citations,
    metadata: {
      model: $model,
      response_id: $response_id,
      elapsed_seconds: $elapsed,
      web_search_count: $web_searches,
      input_tokens: $input_tokens,
      output_tokens: $output_tokens
    }
  }'

# --- Cost estimate to stderr (bc with awk fallback) ---
_calc() {
  bc 2>/dev/null <<< "$1" || awk "BEGIN{printf \"%.4f\", $1}" 2>/dev/null || echo "N/A"
}
if [[ "$MODEL" == *"o3"* ]]; then
  COST=$(_calc "scale=4; ($INPUT_TOKENS * 10 + $OUTPUT_TOKENS * 40) / 1000000 + $WEB_SEARCH_COUNT * 0.01")
else
  COST=$(_calc "scale=4; ($INPUT_TOKENS * 2 + $OUTPUT_TOKENS * 8) / 1000000 + $WEB_SEARCH_COUNT * 0.01")
fi
echo ">>> Estimated cost: \$$COST (tokens: ${INPUT_TOKENS}in/${OUTPUT_TOKENS}out, ${WEB_SEARCH_COUNT} web searches)" >&2
